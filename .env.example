# ===== Common =====
APP_ENV=dev

# ===== Gateway =====
GATEWAY_PORT=8000

# ===== User Service =====
USER_SERVICE_PORT=8001
JWT_SECRET=dev-secret-change-me

# ===== Postgres (auth/users) =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=abook_auth
POSTGRES_USER=abook
POSTGRES_PASSWORD=abook_password
DATABASE_URL=postgres://abook:abook_password@localhost:5432/abook_auth

# ===== Mongo =====
MONGO_URL=mongodb://mongodb:27017

# ===== Redis =====
REDIS_URL=redis://redis:6379

# ===== RabbitMQ =====
RABBITMQ_URL=amqp://abook:abook_password@rabbitmq:5672

# ===== TimescaleDB =====
TIMESCALE_URL=postgres://abook:abook_password@timescaledb:5432/abook_timeseries

# ===== Frontend =====
VITE_API_BASE_URL=/api/v1

